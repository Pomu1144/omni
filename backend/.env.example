# Copy this file to .env (cp backend/.env.example backend/.env) and fill in
# your key. backend/.env is gitignored, so it's only ever read locally.

# ElevenLabs text-to-speech (https://elevenlabs.io/app/settings/api-keys) —
# required for Omni to speak responses out loud in Voice Mode. Without this,
# voice input (browser speech recognition) and text commands still work, but
# responses stay text-only and the dashboard shows a "voice output not
# configured" notice.
ELEVENLABS_API_KEY=

# Premade ElevenLabs voice id. Defaults to "Adam" (calm male voice), matching
# the voice persona described in docs/SPEC.md. Swap for any voice id from
# your ElevenLabs Voice Library: https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# eleven_turbo_v2_5 is ElevenLabs' low-latency model, a good fit for an
# interactive assistant. See https://elevenlabs.io/docs/models for others.
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
